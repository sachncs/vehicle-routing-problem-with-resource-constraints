{
  "name": "vehicle-routing",
  "version": "1.0.0",
  "description": "VRP-RPD Solver with multi-objective optimization",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "vrp-solver": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist docs/api docs/md",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "mocha",
    "test:watch": "mocha --watch",
    "test:coverage": "c8 mocha",
    "docs": "typedoc",
    "docs:md": "typedoc --plugin typedoc-plugin-markdown --out docs/md",
    "typecheck": "tsc --noEmit"
  },
  "c8": {
    "reporter": ["text", "lcov", "html"],
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.d.ts", "src/**/*.test.ts", "tests/**", "dist/**", "demo/**"],
    "check-coverage": true,
    "lines": 75,
    "functions": 75,
    "branches": 75,
    "statements": 75
  },
  "keywords": [
    "vrp",
    "routing",
    "optimization",
    "logistics"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/vrp-rpd.git"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "c8": "^10.0.0",
    "chai": "^6.2.2",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.30.0",
    "mocha": "^11.7.5",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "tslib": "^2.7.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.10"
  }
}
